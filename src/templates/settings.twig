{% extends 'watson/_layout' %}

{% import '_includes/forms' as forms %}

{% set title = 'Settings'|t('watson') %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'settings' %}

{% block actionButton %}
    <button type="submit" class="btn submit">{{ 'Save'|t('app') }}</button>
{% endblock %}

{% block content %}

    <input type="hidden" name="action" value="watson/cp/settings">
    {{ redirectInput('watson/settings') }}

    {% namespace 'settings' %}

        {{ forms.textField({
            label:        'Retention Days'|t('watson'),
            name:         'retentionDays',
            id:           'retentionDays',
            value:        settings.retentionDays,
            type:         'number',
            min:          1,
            instructions: 'Number of days to keep violations. Used by the "Purge old" button and the purge console command.'|t('watson'),
            errors:       settings.getErrors('retentionDays'),
        }) }}

        {{ forms.editableTableField({
            label:        'Ignored Directives'|t('watson'),
            name:         'ignoredDirectives',
            id:           'ignoredDirectives',
            instructions: 'Incoming violations matching these effective directives will not be stored.'|t('watson'),
            cols: {
                col1: {
                    type:        'singleline',
                    heading:     'Directive'|t('watson'),
                    placeholder: 'script-src',
                    code:        true,
                },
            },
            rows:         settings.ignoredDirectives,
            addRowLabel:  'Add a directive'|t('watson'),
            allowAdd:     true,
            allowDelete:  true,
            allowReorder: true,
            errors:       settings.getErrors('ignoredDirectives'),
        }) }}

    {% endnamespace %}

{% endblock %}
