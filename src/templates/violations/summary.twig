{% extends 'watson/_layout' %}

{% set title = 'Violation Summary'|t('watson') %}

{% set selectedSubnavItem = 'summary' %}

{% block content %}

    <form method="get" style="margin-bottom: 1rem;">
        <div class="flex" style="align-items: center; gap: 0.5rem;">
            <label>{{ 'Show top'|t('watson') }}</label>
            <div class="select">
                <select name="limit" onchange="this.form.submit()">
                    {% for n in [10, 20, 50, 100] %}
                        <option value="{{ n }}"{{ n == limit ? ' selected' }}>{{ n }}</option>
                    {% endfor %}
                </select>
            </div>
            <label>{{ 'violations'|t('watson') }}</label>
        </div>
    </form>

    {% if summary|length %}
        {%- set _sortBase = {limit: limit} -%}
        {%- macro _th(label, column, sort, dir, base) -%}
            {%- set _active = sort == column -%}
            {%- set _next = _active and dir == 'asc' ? 'desc' : 'asc' -%}
            <th scope="col"
                class="orderable{{ _active ? ' ordered ' ~ dir }}"
                aria-sort="{{ _active ? (dir == 'asc' ? 'ascending' : 'descending') : 'none' }}">
                <button type="button" data-href="{{ url('watson/violations/summary', base|merge({sort: column, dir: _next})) }}">
                    {{- label -}}<div class="spinner"></div>
                </button>
            </th>
        {%- endmacro -%}

        <table class="data fullwidth">
            <thead>
                <tr>
                    {{ _self._th('Count'|t('watson'),        'count',              sort, dir, _sortBase) }}
                    {{ _self._th('Directive'|t('watson'),    'effectiveDirective', sort, dir, _sortBase) }}
                    {{ _self._th('Blocked URI'|t('watson'),  'blockedUri',         sort, dir, _sortBase) }}
                    {{ _self._th('Document URI'|t('watson'), 'documentUri',        sort, dir, _sortBase) }}
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for group in summary %}
                    <tr>
                        <td><strong>{{ group.count }}</strong></td>
                        <td><code>{{ group.effectiveDirective ?? '—' }}</code></td>
                        <td class="smalltext">{{ group.blockedUri ?? '—' }}</td>
                        <td class="smalltext">{{ group.documentUri ?? '—' }}</td>
                        <td class="nowrap">
                            <a href="{{ url('watson/violations', {
                                effectiveDirective: group.effectiveDirective ?? '',
                                blockedUri: group.blockedUri ?? '',
                                status: ''
                            }) }}" class="btn small">{{ 'View all'|t('watson') }}</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ 'No violations recorded yet.'|t('watson') }}</p>
    {% endif %}

{% endblock %}

{% js %}
document.querySelectorAll('th.orderable button[data-href]').forEach(function (btn) {
    btn.addEventListener('click', function () {
        window.location.href = btn.getAttribute('data-href');
    });
});
{% endjs %}
